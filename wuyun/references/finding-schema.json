{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Aimer-zero/wuyun/schema/finding.schema.json",
  "title": "Wuyun Finding Bundle",
  "type": "object",
  "required": ["findings"],
  "properties": {
    "tool": {"type": "string"},
    "source": {"type": "string"},
    "summary": {"type": "object"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "confidence", "category"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "severity": {"enum": ["critical", "high", "medium", "low", "informational"]},
          "confidence": {"enum": ["high", "medium", "low"]},
          "category": {"type": "string"},
          "path": {"type": "string"},
          "line": {"type": "integer", "minimum": 1},
          "evidence": {"type": "string"},
          "remediation": {"type": "string"},
          "references": {"type": "array", "items": {"type": "string"}},
          "source_tool": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
